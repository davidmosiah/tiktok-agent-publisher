{
  "name": "tiktok-agent-publisher",
  "version": "0.1.1",
  "description": "Local-first TikTok Content Posting API CLI and MCP helper for AI agents.",
  "type": "module",
  "bin": {
    "tiktok-agent-publisher": "src/cli.js",
    "tiktok-agent-mcp": "src/index.js"
  },
  "scripts": {
    "check": "find src test -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test",
    "doctor": "node src/cli.js doctor",
    "manifest": "node src/cli.js manifest",
    "privacy": "node src/cli.js privacy-audit",
    "start": "node src/index.js"
  },
  "keywords": [
    "ai-agents",
    "mcp",
    "model-context-protocol",
    "tiktok",
    "content-posting-api",
    "social-media-automation",
    "cli"
  ],
  "author": "David Mosiah",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidmosiah/tiktok-agent-publisher.git"
  },
  "bugs": {
    "url": "https://github.com/davidmosiah/tiktok-agent-publisher/issues"
  },
  "homepage": "https://github.com/davidmosiah/tiktok-agent-publisher"
}
