TIKTOK_DRY_RUN=true
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_REDIRECT_URI=http://localhost:8787/callback

# Optional media hosting for photo posts or pull-from-url workflows.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
